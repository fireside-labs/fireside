{
  "expo": {
    "name": "Valhalla Companion",
    "slug": "valhalla-companion",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "valhalla",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0f"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.valhalla.companion",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Camera is used to scan QR codes for pairing with your home PC.",
        "NSMicrophoneUsageDescription": "Microphone is used for voice mode to talk to your AI companion."
      }
    },
    "android": {
      "package": "com.valhalla.companion",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#0a0a0f",
        "foregroundImage": "./assets/icon.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-notifications",
      [
        "expo-camera",
        {
          "cameraPermission": "Camera is used to scan QR codes for pairing."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Microphone is used for voice mode."
        }
      ]
    ]
  }
}